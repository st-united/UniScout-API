{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@AuthModule/*": ["src/modules/auth/*"],
      "@Constant/*": ["src/common/constants/*"],
      "@ContactModule/*": ["src/modules/contact/*"],
      "@DashboardModule/*": ["src/modules/dashboard/*"],
      "@Decorators/*": ["src/common/decorators/*"],
      "@Entity/*": ["src/common/entities/*"],
      "@Enums/*": ["src/common/enums/*"],
      "@Guards/*": ["src/common/guards/*"],
      "@Helper/*": ["src/common/helper/*"],
      "@PermissionsModule/*": ["src/modules/permissions/*"],
      "@RolesModule/*": ["src/modules/roles/*"],
      "@UniversitiesModule/*": ["src/modules/universities/*"],
      "@UsersModule/*": ["src/modules/users/*"],
      "@Library/*": ["src/libraries/*"],
      "@app/*": ["src/*"]
    },

    "typeRoots": ["./node_modules/@types", "./src/common/types"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"],
  "files": ["src/modules/universities/import-universities.ts", "src/common/types/express.d.ts"]
}
